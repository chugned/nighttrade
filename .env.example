# nighttrade environment overrides — copy to .env and edit.
# Every variable here is OPTIONAL. The platform runs fully offline with mock data.
#
# SAFETY: there is no variable that enables real trading. By design.
# Real order execution always raises NotImplementedError.

# --- Runtime ---
# Override the active config profile (configs/<profile>.yaml).
NIGHTTRADE_PROFILE=default

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
NIGHTTRADE_LOG_LEVEL=INFO

# Force deterministic behaviour (fixed RNG seeds). Recommended for tests.
NIGHTTRADE_DETERMINISTIC=true

# --- Optional public market data ---
# When false (default), data sources return mock data and never hit the network.
# When true, read-only US stock data is fetched from yfinance / stooq.
NIGHTTRADE_ALLOW_NETWORK=false

# --- Optional macro AI (Gemini) ---
# When unset, the macro engine uses the deterministic mock analyzer.
# GEMINI_API_KEY=

# --- Optional broker SANDBOX (paper account) keys ---
# SANDBOX = a broker PAPER-trading account only. These keys must be PAPER keys
# for a PAPER account; the platform talks exclusively to the paper-trading
# endpoint and refuses any key tied to a LIVE brokerage account. There is no
# live execution path.
#
# Alpaca Paper Trading: https://alpaca.markets/  (create a PAPER account, then
# generate paper API keys from the dashboard).
# ALPACA_PAPER_API_KEY=
# ALPACA_PAPER_API_SECRET=
